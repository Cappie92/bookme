    "test:unit": "jest --config jest.unit.config.js",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "maestro test .maestro/flows/",
    "test:e2e:ios": "maestro test .maestro/flows/ --env APP_ID=com.yourcompany.dedato",
    "test:e2e:android": "maestro test .maestro/flows/ --env APP_ID=com.yourcompany.dedato"
  },
