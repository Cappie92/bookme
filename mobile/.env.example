# API
# Production: один HTTPS endpoint (Android-override не используется).
API_URL=https://api.dedato.ru

# Локальная разработка (симуляторы без ручного переключения одной строки):
#   API_URL — loopback для iOS Simulator и базовое значение;
#   API_URL_ANDROID — только __DEV__ + Android: хост эмулятора → машина разработчика (часто http://10.0.2.2:<PORT>).
# Пример:
# API_URL=http://127.0.0.1:8000
# API_URL_ANDROID=http://10.0.2.2:8000
#
# Физическое устройство: задайте API_URL на LAN IP машины (одна сеть) или используйте adb reverse;
#   оставьте API_URL_ANDROID пустым или удалите строку, чтобы Android брал тот же API_URL.
# Подробнее: mobile/FIX_ANDROID_EMULATOR.md

WEB_URL=https://dedato.ru

# Опционально: доп. хосты для парсинга HTTPS deep links в приложении (через запятую).
# Нативные Associated Domains / App Links задаются при сборке: APP_UNIVERSAL_LINK_HOSTS в EAS/shell
# или автоматически из hostname WEB_URL (см. docs/mobile/UNIVERSAL_APP_LINKS.md).
# EXTRA_UNIVERSAL_LINK_HOSTS=www.dedato.ru

# Debug flags (0/1). Default: 0. Enable only when needed.
DEBUG_AUTH=0
DEBUG_HTTP=0
DEBUG_MENU=0
DEBUG_FEATURES=0
DEBUG_DASHBOARD=0
DEBUG_LOGS=0
# Плавающая кнопка DBG в приложении только при 1 (и __DEV__). Без этого флага панель не монтируется.
# Плавающая DBG: только значение 1 (не true/yes). Иначе FAB не показывается.
DEBUG_MOBILE_ERRORS=0
# Auth trace ring-buffer; секция в DBG при Copy только если SHOW_DBG (строго =1 выше) и DEBUG_AUTH_TRACE.
DEBUG_AUTH_TRACE=0
# Подробные логи auth в Metro: DEBUG_AUTH=1
