{
  "cli": {
    "version": ">= 9.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "https://dedato.ru",
        "WEB_URL": "https://dedato.ru",
        "APP_UNIVERSAL_LINK_HOSTS": "dedato.ru,www.dedato.ru",
        "YANDEX_MOBILE_AUTH_VISIBLE": "0"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "API_URL": "https://dedato.ru",
        "WEB_URL": "https://dedato.ru",
        "APP_UNIVERSAL_LINK_HOSTS": "dedato.ru,www.dedato.ru",
        "YANDEX_MOBILE_AUTH_VISIBLE": "0"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
