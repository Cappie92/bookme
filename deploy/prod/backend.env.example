###############################################################################
# DeDato production env template (backend)
#
# ВАЖНО:
# - Не коммитить реальные секреты. На сервере создайте deploy/prod/backend.env
#   по этому шаблону.
# - Для первого прод-запуска с переносом текущего reseed dataset используем SQLite
#   в docker volume (см. docker-compose.prod.yml).
###############################################################################

ENVIRONMENT=production

# Auth
# ОБЯЗАТЕЛЬНО: в production нельзя использовать дефолтное значение.
JWT_SECRET_KEY=CHANGE_ME_TO_STRONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS=30

# URLs (используются в платежах / ссылках / CORS)
FRONTEND_URL=https://dedato.ru
API_BASE_URL=https://dedato.ru

# Database
# В docker-compose.prod.yml задаётся DATABASE_URL=sqlite:////data/bookme.db
# Не дублируйте DATABASE_URL здесь, если не хотите случайно переопределить compose.

# Dev-only toggles (ОБЯЗАТЕЛЬНО оставить выключенными на проде)
ENABLE_DEV_TESTDATA=
# В production код игнорирует DEV_E2E (роуты не монтируются); оставляйте пустым для ясности.
DEV_E2E=

# Features (оставляйте пустыми если фича не используется)
SALONS_ENABLED=
LEGACY_INDIE_MODE=0

# Redis (OTP-хранилище для backend/sms.py).
# В docker-compose.prod.yml Redis поднимается и для backend принудительно выставляется:
#   REDIS_HOST=redis
# Значения ниже — для локального запуска вне compose (если вам это нужно).
REDIS_HOST=localhost
REDIS_PORT=6379

# Payments (Robokassa) — включайте только если реально используете.
# Если не используете, оставьте ROBOKASSA_MODE пустым или "stub".
ROBOKASSA_MODE=stub
ROBOKASSA_IS_TEST=false
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD_1=
ROBOKASSA_PASSWORD_2=
ROBOKASSA_TEST_PASSWORD_1=
ROBOKASSA_TEST_PASSWORD_2=
ROBOKASSA_RESULT_URL=
ROBOKASSA_SUCCESS_URL=
ROBOKASSA_FAIL_URL=

# Telephony / SMS — включайте только если реально используете.
ZVONOK_MODE=stub
ZVONOK_API_KEY=
PLUSOFON_MODE=stub
PLUSOFON_USER_ID=
PLUSOFON_ACCESS_TOKEN=

