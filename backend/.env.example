# Backend env — скопируйте в .env и подставьте значения
# Единый источник правды: backend/settings.py (get_settings())
# Минимальный набор для локального старта: JWT_SECRET_KEY, DATABASE_URL
# В production секреты без дефолтов; при включённых фичах (не stub) обязательны соответствующие переменные

# --- Обязательные ---
JWT_SECRET_KEY=your-super-secret-key
DATABASE_URL=sqlite:///./bookme.db

# --- Режим и CORS ---
# ENVIRONMENT=development
# ENABLE_DEV_TESTDATA=
# DEV_E2E=

# --- Auth (опционально) ---
# ACCESS_TOKEN_EXPIRE_DAYS=7
# REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Feature flags ---
# SALONS_ENABLED=true
# LEGACY_INDIE_MODE=0
# MASTER_CANON_DEBUG=0

# --- Отладка маршрутов (uvicorn startup) ---
# DEDATO_DEBUG_ROUTES=1   # залогировать POST/PUT /api/master/schedule/day и catch-all
# DEDATO_LOG_ENTRYPOINT=1 # напоминание команды: python3 -m uvicorn main:app ...

# --- URLs (письма, платежи) ---
# FRONTEND_URL=http://localhost:5175
# API_BASE_URL=http://localhost:8000

# --- Демо-мастер (read-only PUT в кабинете) ---
# Не задавайте номер из канона reseed: +79990000000 … +79990000009 (MASTER_PHONES в reseed_local_test_data.py),
# иначе соответствующий тестовый мастер получит 403 на обновление профиля.
# Дефолт в settings.py: +79990009999
# DEMO_MASTER_PHONE=+79990009999

# --- Robokassa (локально обычно stub) ---
# ROBOKASSA_MODE=stub
# ROBOKASSA_MERCHANT_LOGIN=
# Боевые пароли (только при ROBOKASSA_IS_TEST=false)
# ROBOKASSA_PASSWORD_1=
# ROBOKASSA_PASSWORD_2=
# Тестовый режим Robokassa: IsTest=1, отдельные тестовые пароли из ЛК
# ROBOKASSA_IS_TEST=false
# ROBOKASSA_TEST_PASSWORD_1=
# ROBOKASSA_TEST_PASSWORD_2=
# ROBOKASSA_RESULT_URL=
# ROBOKASSA_SUCCESS_URL=
# ROBOKASSA_FAIL_URL=
# Только для осознанного local stub: при ROBOKASSA_IS_TEST=true не подставлять боевые пароли без opt-in
# ROBOKASSA_ALLOW_INSECURE_PROD_PASSWORDS_IN_TEST=false
#
# Шаблоны без смешения тест/прод:
#   .env.robokassa-test.local.example — локальный ручной тест Robokassa (test mode)
#   .env.production.example — боевой Robokassa (шаблон для деплоя)
# Runbook: docs/robokassa_test_mode.md

# --- Redis (SMS коды) ---
# REDIS_HOST=localhost
# REDIS_PORT=6379

# --- Телефония (опционально) ---
# ZVONOK_API_KEY=
# ZVONOK_MODE=stub
# PLUSOFON_USER_ID=
# PLUSOFON_ACCESS_TOKEN=
# PLUSOFON_MODE=stub
