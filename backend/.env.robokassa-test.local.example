# =============================================================================
# LOCAL TEST ONLY — DO NOT USE IN PROD
#
# Шаблон для ручного тестирования Robokassa в тестовом режиме на локальной машине.
#
# Как использовать:
#   1) cp .env.robokassa-test.local.example .env.robokassa-test.local
#   2) Заполните значения из личного кабинета Robokassa (тестовые пароли #1 / #2).
#   3) Подставьте публичный URL туннеля вместо YOUR_TUNNEL_HOST (ResultURL недоступен с localhost).
#   4) Запуск: python3 scripts/run_backend_robokassa_test.py  (см. docs/robokassa_test_mode.md)
#
# Файл .env.robokassa-test.local не коммитится (см. .gitignore: .env.*.local).
# =============================================================================

ENVIRONMENT=development

# --- Robokassa: только тестовый режим ---
ROBOKASSA_IS_TEST=true
# Не "stub", если нужен реальный тестовый checkout на стороне Robokassa
ROBOKASSA_MODE=production
ROBOKASSA_MERCHANT_LOGIN=YOUR_MERCHANT_LOGIN

# Тестовые пароли из раздела «Тест» / тестовые настройки в ЛК Robokassa
ROBOKASSA_TEST_PASSWORD_1=
ROBOKASSA_TEST_PASSWORD_2=

# Боевые пароли намеренно пустые — не смешивать с тестовыми
ROBOKASSA_PASSWORD_1=
ROBOKASSA_PASSWORD_2=

# База API для формирования ссылок (должна совпадать с публичным URL туннеля)
API_BASE_URL=https://YOUR_TUNNEL_HOST
FRONTEND_URL=http://localhost:5175

# Callback и редиректы: ResultURL должен быть ДОСТУПЕН из интернета (не 127.0.0.1)
ROBOKASSA_RESULT_URL=https://YOUR_TUNNEL_HOST/api/payments/robokassa/result
ROBOKASSA_SUCCESS_URL=https://YOUR_TUNNEL_HOST/payment/success
ROBOKASSA_FAIL_URL=https://YOUR_TUNNEL_HOST/payment/fail
