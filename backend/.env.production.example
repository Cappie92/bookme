# =============================================================================
# PRODUCTION TEMPLATE — Robokassa (боевой режим)
#
# Не коммитить реальные секреты. Скопируйте нужные строки в секреты деплоя / .env на сервере.
# Для локального теста Robokassa используйте .env.robokassa-test.local.example, не этот файл.
# =============================================================================

ENVIRONMENT=production

ROBOKASSA_IS_TEST=false
ROBOKASSA_MODE=production
ROBOKASSA_MERCHANT_LOGIN=YOUR_MERCHANT_LOGIN

# Боевые пароли #1 / #2 из личного кабинета Robokassa (боевой магазин)
ROBOKASSA_PASSWORD_1=YOUR_PRODUCTION_PASSWORD_1
ROBOKASSA_PASSWORD_2=YOUR_PRODUCTION_PASSWORD_2

# В production тестовые пароли не используются — оставьте пустыми
ROBOKASSA_TEST_PASSWORD_1=
ROBOKASSA_TEST_PASSWORD_2=

API_BASE_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

ROBOKASSA_RESULT_URL=https://api.yourdomain.com/api/payments/robokassa/result
ROBOKASSA_SUCCESS_URL=https://yourdomain.com/payment/success
ROBOKASSA_FAIL_URL=https://yourdomain.com/payment/fail
